<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Anxon - Tu Red de Video</title>
    <style>
        /* Estilo General - Inspiración Dark/Tech */
        body {
            background-color: #050505;
            color: #ffffff;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100vh;
            overflow: hidden;
        }

        /* El Logo Anxon */
        .logo {
            font-size: 4rem;
            font-weight: bold;
            letter-spacing: -2px;
            color: #008cff; /* Azul neón tipo Orden Azul */
            text-shadow: 0 0 20px rgba(0, 140, 255, 0.5);
            margin-bottom: 10px;
        }

        /* La Bienvenida que pediste */
        .welcome-text {
            font-size: 1.5rem;
            color: #888;
            margin-bottom: 30px;
            font-style: italic;
        }

        /* Botones de Acción */
        .btn-container {
            display: flex;
            gap: 20px;
        }

        .btn {
            background: transparent;
            border: 1px solid #008cff;
            color: #008cff;
            padding: 12px 30px;
            border-radius: 30px;
            cursor: pointer;
            font-weight: bold;
            transition: 0.3s;
            text-decoration: none;
        }

        .btn:hover {
            background: #008cff;
            color: white;
            box-shadow: 0 0 15px #008cff;
        }

        /* Animación simple */
        .fade-in {
            animation: fadeIn 2s ease-in;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>
<body>

    <div class="logo fade-in">ANXON</div>
    <div class="welcome-text fade-in">Bienvenido/a al anexo</div>

    <div class="btn-container fade-in">
        <a href="#" class="btn">Explorar Videos</a>
        <a href="#" class="btn" style="background: #008cff; color: white;">Registrarse</a>
    </div>

</body>
</html>
